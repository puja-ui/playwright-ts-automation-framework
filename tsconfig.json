{
  "compilerOptions": {
    "target": "ES2022",                          /* Target modern ECMAScript features */
    "module": "commonjs",                        /* Standard module resolution */
    "moduleResolution": "node",                  /* Resolve modules using Node.js style */
    "strict": true,                              /* Enable all strict type-checking options */
    "esModuleInterop": true,                     /* Enables emit interoperability */
    "skipLibCheck": true,                        /* Skip type checking of declaration files */
    "forceConsistentCasingInFileNames": true     /* Disallow inconsistently-cased references */
  },
  "include": ["tests/**/*.ts", "pages/**/*.ts"]  /* Ensure your test and page folders are tracked */
}